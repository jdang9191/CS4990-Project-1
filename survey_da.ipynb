    "import pandas as pd\n",
    "\n",
    "df = pd.read_csv(\"cs4900responses.csv\")\n",
    "\n",
    "# clean up common junk cols + whitespace\n",
    "df = df.loc[:, ~df.columns.str.contains(r\"^Unnamed\")]\n",
    "df.columns = df.columns.str.strip().str.replace(r\"\\s+\", \" \", regex=True)\n",
    "\n",
    "df.head()"
   ]
